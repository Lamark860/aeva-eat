# Database
DB_NAME=aeva_eat
DB_USER=aeva
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_STRING_64_CHARS

# App
APP_PORT=80

# Яндекс Карты — Геосаджест (backend проксирует /api/suggest)
# Кабинет: https://developer.tech.yandex.ru/services — сервис "JavaScript API и HTTP Геокодер" / "Геосаджест"
GEOSUGGEST_KEY=CHANGE_ME_YANDEX_GEOSUGGEST_KEY

# Яндекс Карты — JS API ключ (печётся во фронтенд-бандл на этапе сборки)
# Кабинет: тот же, сервис "JavaScript API и HTTP Геокодер"
VITE_YANDEX_MAPS_KEY=CHANGE_ME_YANDEX_JS_API_KEY
